<?xml version="1.0" encoding="UTF-8" standalone="yes" ?>
<CodeBlocks_project_file>
	<FileVersion major="1" minor="6" />
	<Project>
		<Option title="Terraria" />
		<Option pch_mode="2" />
		<Option compiler="gcc-msys2-mingw64" />
		<Build>
			<Target title="Debug">
				<Option output="bin/Debug/Terraria" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Debug/" />
				<Option type="0" />
				<Option compiler="gcc-msys2-mingw64" />
				<Compiler>
					<Add option="-g" />
				</Compiler>
			</Target>
			<Target title="Release">
				<Option output="bin/Release/Terraria" prefix_auto="1" extension_auto="1" />
				<Option object_output="obj/Release/" />
				<Option type="0" />
				<Option compiler="gcc-msys2-mingw64" />
				<Compiler>
					<Add option="-O2" />
				</Compiler>
				<Linker>
					<Add option="-s" />
				</Linker>
			</Target>
		</Build>
		<Compiler>
			<Add option="-Wall" />
			<Add directory="$(#sdl.include)" />
		</Compiler>
		<Linker>
			<Add library="mingw32" />
			<Add library="SDLmain" />
			<Add library="SDL.dll" />
			<Add library="user32" />
			<Add library="gdi32" />
			<Add library="winmm" />
			<Add library="dxguid" />
			<Add library="SDL_gfx" />
			<Add library="SDL_ttf" />
			<Add library="SDL_image" />
			<Add library="SDL_mixer" />
			<Add directory="$(#sdl.lib)" />
		</Linker>
		<Unit filename="bin/Debug/stdout.txt" />
		<Unit filename="src/chunk.h" />
		<Unit filename="src/entity.h" />
		<Unit filename="src/entity_type.h" />
		<Unit filename="src/glob.h" />
		<Unit filename="src/input_handling.h" />
		<Unit filename="src/input_signals.h" />
		<Unit filename="src/item.h" />
		<Unit filename="src/main.c">
			<Option compilerVar="CC" />
		</Unit>
		<Unit filename="src/nearest_neighbor.h" />
		<Unit filename="src/perlin_noise.h" />
		<Unit filename="src/renderer.h" />
		<Unit filename="src/scene_type.h" />
		<Unit filename="src/texture.h" />
		<Extensions>
			<lib_finder disable_auto="1" />
		</Extensions>
	</Project>
</CodeBlocks_project_file>
